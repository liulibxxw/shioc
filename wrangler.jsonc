{
  "name": "oc",
  "compatibility_date": "2026-07-07",
  // 入口 Worker：处理 /api/* 数据同步，其余路径回落到静态资源
  "main": "worker/index.js",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    // 让 Worker 能通过 env.ASSETS 兜底静态资源
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  // 线上数据同步：站点数据与编辑口令散列都存这份 KV
  "kv_namespaces": [
    {
      "binding": "OC_DATA",
      "id": "ce0d4c1a23ee4183a0905ea488693afb"
    }
  ]
}
